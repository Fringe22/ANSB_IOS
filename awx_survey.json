{
  "name": "Cisco IOS XR Upgrade",
  "description": "Upgrade a Cisco IOS XR device using the install add/activate workflow. Optional SMU batches may be applied before and/or after the version upgrade. Restart type (reload vs process-restart) is auto-detected per SMU.",
  "spec": [
    {
      "question_name": "Target IOS XR version",
      "question_description": "Must match `show install active summary` Label: line exactly after upgrade.",
      "required": true,
      "type": "text",
      "variable": "target_version",
      "min": 3,
      "max": 32,
      "default": "24.4.2.1",
      "choices": "",
      "new_question": true
    },
    {
      "question_name": "Image path on device",
      "question_description": "Filesystem where the image and SMUs are staged.",
      "required": true,
      "type": "multiplechoice",
      "variable": "image_path",
      "min": 0,
      "max": 1024,
      "default": "harddisk:",
      "choices": "harddisk:\nharddiskb:\ndisk0:\nflash:",
      "new_question": true
    },
    {
      "question_name": "Base image filename",
      "question_description": "TAR bundle or ISO already staged at the image path above.",
      "required": true,
      "type": "text",
      "variable": "image_file",
      "min": 5,
      "max": 128,
      "default": "asr9k-x64-24.4.2.1.tar",
      "choices": "",
      "new_question": true
    },
    {
      "question_name": "Image file MD5",
      "question_description": "32-char hex. Generate with `md5sum <filename>` on the file server.",
      "required": true,
      "type": "text",
      "variable": "image_file_md5",
      "min": 32,
      "max": 32,
      "default": "",
      "choices": "",
      "new_question": true
    },
    {
      "question_name": "SMUs BEFORE upgrade (filename: md5, one per line)",
      "question_description": "Patches the CURRENT image. Committed immediately. Leave empty to skip.\nExample:\n  asr9k-sysadmin-asr9k-7.8.2.4-r782.CSCwh61644.x86_64.rpm: 6f58dd1f3d1b2df3f1c6c447b2a6f31b\n  asr9k-iosxr-install-1.0.0.2-r782.CSCwi95358.x86_64.rpm: 9fd66427f14de49eb7d651aca9abfc86",
      "required": false,
      "type": "textarea",
      "variable": "smus_before_combined",
      "min": 0,
      "max": 4096,
      "default": "",
      "choices": "",
      "new_question": true
    },
    {
      "question_name": "SMUs AFTER upgrade (filename: md5, one per line)",
      "question_description": "Applied on top of the NEW image. Committed atomically with the version upgrade. Leave empty to skip.\nExample:\n  asr9k-sysadmin-install-24.4.2.1-r2442.CSCwq57215.x86_64.rpm: 9388c698b52d9f08145a606d09c71915",
      "required": false,
      "type": "textarea",
      "variable": "smus_after_combined",
      "min": 0,
      "max": 4096,
      "default": "",
      "choices": "",
      "new_question": true
    },
    {
      "question_name": "Run DISK-PREP phase",
      "question_description": "Remove core files and inactive packages before upgrade.",
      "required": false,
      "type": "multiplechoice",
      "variable": "disk_prep_enabled",
      "min": 0,
      "max": 1024,
      "default": "true",
      "choices": "true\nfalse",
      "new_question": true
    },
    {
      "question_name": "Run FPD-PREP phase",
      "question_description": "Disable FPD auto-upgrade/auto-reload before the image install.",
      "required": false,
      "type": "multiplechoice",
      "variable": "fpd_prep_enabled",
      "min": 0,
      "max": 1024,
      "default": "true",
      "choices": "true\nfalse",
      "new_question": true
    },
    {
      "question_name": "Run FPD upgrade phase",
      "question_description": "Upgrade all FPDs after image install (sequenced first if listed, then bulk).",
      "required": false,
      "type": "multiplechoice",
      "variable": "fpd_upgrade_enabled",
      "min": 0,
      "max": 1024,
      "default": "true",
      "choices": "true\nfalse",
      "new_question": true
    },
    {
      "question_name": "FPD admin reload after upgrade",
      "question_description": "Required for BIOS-class FPD changes.",
      "required": false,
      "type": "multiplechoice",
      "variable": "fpd_reload_required",
      "min": 0,
      "max": 1024,
      "default": "true",
      "choices": "true\nfalse",
      "new_question": true
    },
    {
      "question_name": "Sequenced FPD upgrades (YAML list)",
      "question_description": "Field-notice-driven ordering. Leave as [] to skip.\nExample:\n  - { location: \"0/1\", fpd: \"Sunstreaker\" }\n  - { location: \"0/1\", fpd: \"Primary-BIOS\" }",
      "required": false,
      "type": "textarea",
      "variable": "fpd_sequenced_upgrades",
      "min": 0,
      "max": 4096,
      "default": "[]",
      "choices": "",
      "new_question": true
    },
    {
      "question_name": "Parallel upgrades",
      "question_description": "How many devices to upgrade at once. '1' = one at a time (safest). Higher values run that many in parallel.",
      "required": false,
      "type": "multiplechoice",
      "variable": "upgrade_serial",
      "min": 0,
      "max": 1024,
      "default": "1",
      "choices": "1\n2\n3\n5\n10",
      "new_question": true
    },
    {
      "question_name": "Reload timeout (seconds)",
      "question_description": "Max wait for SSH to return after a reload.",
      "required": false,
      "type": "integer",
      "variable": "reload_timeout",
      "min": 600,
      "max": 7200,
      "default": 2700,
      "choices": "",
      "new_question": true
    },
    {
      "question_name": "Commit soak delay (seconds)",
      "question_description": "Pause between POST checks and `install commit`.",
      "required": false,
      "type": "integer",
      "variable": "commit_delay",
      "min": 0,
      "max": 3600,
      "default": 900,
      "choices": "",
      "new_question": true
    },
    {
      "question_name": "Backup directory (on AWX worker)",
      "question_description": "Where pre/post snapshots are saved.",
      "required": false,
      "type": "text",
      "variable": "backup_dir",
      "min": 1,
      "max": 256,
      "default": "./backups",
      "choices": "",
      "new_question": true
    }
  ]
}
